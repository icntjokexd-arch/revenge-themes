{
  "name": "Asteroid AMOLED Cyan Glass",
  "description": "Mobile AMOLED glass Discord with cyan neon accents",
  "authors": [{ "name": "zRxdra" }],
  "spec": 2,

  "background": {
    "url": "https://i.imgur.com/2KHsvGo.jpeg",
    "alpha": 1,
    "blur": 0
  },

  "colors": {
    "primary": "#00E5FF",
    "secondary": "#6FF4FF",
    "accent": "#00C8FF",

    "backgroundPrimary": "#000000",
    "backgroundSecondary": "#000000",
    "backgroundTertiary": "#000000",

    "chatBackground": "rgba(12,12,12,0.88)",
    "chatBorder": "rgba(0,229,255,0.25)",

    "surfacePrimary": "rgba(18,18,18,0.92)",
    "surfaceSecondary": "rgba(30,30,30,0.92)",
    "surfaceTertiary": "rgba(45,45,45,0.92)",

    "chatButtons": "rgba(22,22,22,0.92)",

    "textNormal": "#FFFFFF",
    "textMuted": "#9ECED8",
    "textLink": "#00E5FF",

    "mentionBackground": "rgba(0,229,255,0.14)",
